<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/reportTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="AI Health Report"
            android:textColor="?attr/colorOnBackground"
            android:textSize="26sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp">

            <TableLayout
                android:id="@+id/reportTable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:stretchColumns="0">

                <TableRow
                    android:background="?attr/colorSurfaceVariant"
                    android:padding="12dp">

                    <TextView
                        android:text="Parameter"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:gravity="end"
                        android:text="Value"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </TableRow>
                <!-- Rows will be added dynamically -->
            </TableLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/aiExplanationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/edittext_bg"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:text="Generating AI insights..."
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp" />

        <!-- RESTORED: Ask AI Button -->
        <Button
            android:id="@+id/askAiButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="💬 Ask Swasthya AI"
            android:textAllCaps="false"
            app:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:text="Disclaimer: This report is generated by AI and is for informational purposes only. Consult a doctor for medical advice."
            android:textColor="?attr/colorOnBackground"
            android:textSize="11sp"
            android:textStyle="italic" />

        <Button
            android:id="@+id/viewRecommendationsButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:text="View Recommendations"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
